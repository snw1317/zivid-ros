<launch>
  <arg name="serial_number" default="" description="Serial number of camera to connect to"/>
  <arg name="settings_2d_file_path" default="" description="Path to a 2D settings file for capture_2d"/>
  <arg name="settings_2d_yaml" default="" description="Inline 2D settings YAML for capture_2d"/>
  <arg name="auto_capture_2d" default="false" description="Continuously trigger capture_2d when available"/>
  <arg name="capture_2d_rate" default="30.0" description="Rate in Hz for auto capture_2d triggers"/>
  <arg name="capture_2d_oneshot" default="true" description="Trigger capture_2d once and exit"/>
  <arg name="capture_2d_stop_on_failure" default="true" description="Exit after first capture_2d failure"/>
  <arg name="capture_2d_wait_for_service_timeout_s" default="5.0" description="Seconds to wait for capture_2d service"/>
  <node pkg="zivid_camera" exec="zivid_camera" name="zivid_camera">
    <param name="serial_number" value="$(var serial_number)"/>
    <param name="settings_2d_file_path" value="$(var settings_2d_file_path)"/>
    <param name="settings_2d_yaml" value="$(var settings_2d_yaml)"/>
  </node>
  <node pkg="zivid_camera" exec="capture_2d_trigger" name="capture_2d_trigger" if="$(var auto_capture_2d)">
    <param name="rate_hz" value="$(var capture_2d_rate)"/>
    <param name="oneshot" value="$(var capture_2d_oneshot)"/>
    <param name="stop_on_failure" value="$(var capture_2d_stop_on_failure)"/>
    <param name="wait_for_service_timeout_s" value="$(var capture_2d_wait_for_service_timeout_s)"/>
  </node>

  <!-- Specify the Zivid camera model for the URDF. See available options in `README.md`. -->
  <arg name="model" default="ZIVID_2_M70" />
  <!-- Specify the visibility of the field of view of the camera model for the URDF. -->
  <arg name="field_of_view" default="false" />
  <node pkg="robot_state_publisher" name="robot_state_publisher" exec="robot_state_publisher">
    <param
      name="robot_description"
      value="$(command '$(find-exec xacro) $(find-pkg-share zivid_description)/urdf/zivid_camera.urdf.xacro model:=$(var model) field_of_view:=$(var field_of_view)')"
    />
  </node>
</launch>
